# Exemplo de arquivo .env - NÃO comite o arquivo real (.env)
# Copie este arquivo para `.env` e preencha com valores reais

# Banco de dados
DB_NAME=skillio_db
DB_USER=skillio_user
DB_PASSWORD=change_me_secure_password

# Django
SECRET_KEY=django-insecure-CHANGE-THIS-TO-A-SECRET
DEBUG=1

# Serviços / APIs
GOOGLE_API_KEY=your_google_api_key_here
VITE_API_URL=http://localhost:8000

# EmailJS
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_USER_ID=your_user_id

# Supabase
VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# YouTube API
VITE_YOUTUBE_API_KEY=your_youtube_api_key

# Redis
REDIS_URL=redis://redis:6379/0
# ════════════════════════════════════════════════════════════════
# SKILLIO - Configurações de Ambiente
# ════════════════════════════════════════════════════════════════
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (na raiz do projeto)
# 2. Preencha os valores das variáveis
# 3. NÃO commite o arquivo .env no Git (está no .gitignore)
# 
# ════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# 🗄️ BANCO DE DADOS (PostgreSQL)
# ────────────────────────────────────────────────────────────────
DB_NAME=skillio_db
DB_USER=postgres
DB_PASSWORD=Skillio*7
# DB_HOST será "db" dentro do Docker, ou "localhost" fora do Docker
# DB_PORT=5432

# ────────────────────────────────────────────────────────────────
# 🔐 DJANGO / BACKEND
# ────────────────────────────────────────────────────────────────
# ATENÇÃO: Gere uma nova SECRET_KEY para produção!
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-this-in-production

# Debug mode (0 = desativado, 1 = ativado)
# SEMPRE use 0 em produção!
DEBUG=1

# Hosts permitidos (separados por vírgula, sem espaços)
# Exemplo: localhost,127.0.0.1,seudominio.com
ALLOWED_HOSTS=*

# CORS - Origens permitidas (separadas por vírgula, sem espaços)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:80,http://localhost

# ────────────────────────────────────────────────────────────────
# 🤖 APIs EXTERNAS - Google
# ────────────────────────────────────────────────────────────────
# Google Generative AI (Gemini)
# Obtenha em: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# ────────────────────────────────────────────────────────────────
# 📧 EmailJS (Sistema de envio de emails)
# ────────────────────────────────────────────────────────────────
# Obtenha em: https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_USER_ID=

# ────────────────────────────────────────────────────────────────
# 💾 Supabase (Armazenamento)
# ────────────────────────────────────────────────────────────────
# Obtenha em: https://supabase.com/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ────────────────────────────────────────────────────────────────
# 🎬 YouTube API
# ────────────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com/
VITE_YOUTUBE_API_KEY=

# ────────────────────────────────────────────────────────────────
# 🤖 Google Generative Language API (Frontend)
# ────────────────────────────────────────────────────────────────
# Pode ser a mesma chave do GOOGLE_API_KEY
VITE_GOOGLE_GENERATIVE_LANGUAGE_API_KEY=

# ────────────────────────────────────────────────────────────────
# 🌐 URLs DA APLICAÇÃO
# ────────────────────────────────────────────────────────────────
# URL base da API (usado pelo frontend)
VITE_API_URL=http://localhost:8000

# ────────────────────────────────────────────────────────────────
# ☁️ AWS (Opcional - para deploy)
# ────────────────────────────────────────────────────────────────
# Descomente e preencha se for fazer deploy na AWS
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-2

# ────────────────────────────────────────────────────────────────
# 📊 REDIS (Cache - Opcional)
# ────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis:6379/0

# ────────────────────────────────────────────────────────────────
# 📧 EMAIL SMTP (Opcional - para emails do Django)
# ────────────────────────────────────────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=seu-email@gmail.com
# EMAIL_HOST_PASSWORD=sua-senha-de-app

# ────────────────────────────────────────────────────────────────
# 🔒 SEGURANÇA (Produção)
# ────────────────────────────────────────────────────────────────
# Descomente estas linhas em produção:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# ════════════════════════════════════════════════════════════════
# FIM DAS CONFIGURAÇÕES
# ════════════════════════════════════════════════════════════════
